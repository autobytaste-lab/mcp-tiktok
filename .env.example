# ──────────────────────────────────────────────────────────────────────────────
# TikTok Developer App Credentials
# Get these from https://developers.tiktok.com → your app → Manage app
#
# SECURITY: These values are read ONLY by the server process from the
# environment.  They are NEVER passed as tool parameters, so the MCP client
# (and the AI model) cannot read them.
#
# For local development: copy this file to .env and fill in the values.
# For production: set these in your MCP host config (see README).
# ──────────────────────────────────────────────────────────────────────────────

TIKTOK_CLIENT_KEY=your_client_key_here
TIKTOK_CLIENT_SECRET=your_client_secret_here

# Optional: default redirect URI (can also be passed per-call to tiktok_get_auth_url)
TIKTOK_REDIRECT_URI=http://localhost:3000/callback

# Optional: override access token (skips ~/.config/mcp-tiktok/tokens.json, useful in CI)
# TIKTOK_ACCESS_TOKEN=act.example...
