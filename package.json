{
  "name": "mcp-tiktok",
  "version": "1.0.0",
  "description": "Full-featured MCP server for TikTok APIs - OAuth, Display API, Content Posting, Research API, Webhooks & more",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-tiktok": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.7.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "tiktok",
    "content-posting",
    "automation",
    "video",
    "image"
  ],
  "license": "MIT"
}
